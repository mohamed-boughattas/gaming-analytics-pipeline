# Gaming Analytics Pipeline Environment Variables

# API Keys (Required for data ingestion)
RAWG_API_KEY=your_rawg_api_key_here

# Database Configuration
DUCKDB_PATH=data/gaming_analytics.duckdb

# Pipeline Configuration
ENVIRONMENT=development
BATCH_SIZE=100
MAX_RETRIES=3
RETRY_DELAY=5
PARALLEL_REQUESTS=5

# Prefect Configuration
PREFECT_API_URL=http://localhost:4200/api
PREFECT_ORION_UI_URL=http://localhost:4200

# Soda Core Configuration
SODA_CONFIGURATION_FILE=src/gaming_pipeline/quality/configuration.yml